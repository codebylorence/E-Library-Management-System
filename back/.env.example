# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database ───────────────────────────────────────────────
# Option A: Render PostgreSQL (use DATABASE_URL — takes priority)
DATABASE_URL=postgresql://user:password@host/dbname

# Option B: Local MySQL (used when DATABASE_URL is not set)
DB_NAME=elibrary_db
DB_USER=root
DB_PASSWORD=your_db_password
DB_HOST=localhost

# ── Sequelize sync ─────────────────────────────────────────
# Set to "true" ONCE on first deploy to create all tables, then set back to "false"
DB_SYNC_ALTER=false

# ── Auth ───────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_32_chars_minimum

# ── Admin seed ─────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_NAME=Library Admin

# ── Google OAuth ───────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── URLs ───────────────────────────────────────────────────
# Set to your Render backend URL
BACKEND_URL=https://your-app.onrender.com
# Set to your frontend URL (Vercel/Netlify/same as backend)
FRONTEND_URL=https://your-app.onrender.com

# ── Kiosk ──────────────────────────────────────────────────
KIOSK_PIN=change_this_pin
